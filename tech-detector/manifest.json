{
  "manifest_version": 3,
  "name": "Tech Detector",
  "version": "1.1.0",
  "description": "Detect technologies and phishing status of websites",

  "permissions": [
    "webRequest",
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://www.virustotal.com/*",
    "https://api.checkphish.ai/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "techdetector@gmail.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}